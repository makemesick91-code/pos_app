<?xml version="1.0" encoding="utf-8"?>
<!--
  UIX-7 transport security (UIX7-R027/R047/R048, rule 30/80 HTTPS posture).

  This is the DEFAULT policy that ships in the `pilot` and `release` (physical
  device / production) variants: cleartext HTTP is DENIED for every host and only
  the standard Android system certificate store is trusted. There is NO trust-all
  anchor and NO hostname-validation override, so the pilot backend
  (https://aishpos.online) is reached strictly over validated TLS.

  Local emulator/dev cleartext exceptions live ONLY in the debug source set
  (src/debug/res/xml/network_security_config.xml) and must never merge into the
  pilot or release variants (UIX7-R048).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
