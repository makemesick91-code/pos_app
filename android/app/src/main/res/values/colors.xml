<?xml version="1.0" encoding="utf-8"?>
<!-- Aish POS — Android color resources.
     Source of truth: operator-provided UI/UX handoff package (DESIGN_TOKENS.json / tokens/colors.xml).
     UIX-1 Design Foundation Lock. Do NOT hardcode hex in layouts/Kotlin — reference these semantic tokens. -->
<resources>
    <!-- Brand -->
    <color name="brand_dark">#0B1020</color>
    <color name="brand_secondary">#6D5DFB</color>
    <color name="brand_support">#06B6D4</color>
    <color name="brand_premium">#D6A84B</color>

    <!-- Action -->
    <color name="action_primary">#2563EB</color>
    <color name="action_primary_pressed">#1D4ED8</color>
    <color name="action_success">#15803D</color>
    <color name="action_success_pressed">#136332</color>
    <color name="action_destructive">#B91C1C</color>

    <!-- Background & surface -->
    <color name="bg_default">#F7F9FC</color>
    <color name="bg_subtle">#F1F4F9</color>
    <color name="surface_default">#FFFFFF</color>

    <!-- Text -->
    <color name="text_primary">#111827</color>
    <color name="text_secondary">#64748B</color>
    <color name="text_disabled">#9CA3AF</color>
    <color name="text_on_dark">#FFFFFF</color>
    <color name="text_on_dark_muted">#B9C5E8</color>
    <color name="text_on_dark_subtle">#8EA3D8</color>

    <!-- Border -->
    <color name="border_default">#E2E8F0</color>
    <color name="border_subtle">#EEF2F7</color>

    <!-- Status: success -->
    <color name="status_success_fg">#15803D</color>
    <color name="status_success_bg">#E7F4EA</color>
    <color name="status_success_border">#BFE3C8</color>

    <!-- Status: warning -->
    <color name="status_warning_fg">#B45309</color>
    <color name="status_warning_bg">#FBF0DC</color>
    <color name="status_warning_border">#F0DDB4</color>
    <color name="status_warning_text_dark">#7C5A16</color>

    <!-- Status: danger -->
    <color name="status_danger_fg">#B91C1C</color>
    <color name="status_danger_bg">#FBE7E7</color>
    <color name="status_danger_border">#F2C9C9</color>

    <!-- Status: info -->
    <color name="status_info_fg">#1D4ED8</color>
    <color name="status_info_bg">#E8EEFC</color>
    <color name="status_info_border">#C7D6F5</color>

    <!-- Semantic aliases used for UIX-1 migration of legacy hardcoded values.
         Kept token-derived so a single source drives all surfaces. -->
    <color name="divider">#E2E8F0</color>
    <color name="scrim_subtle">#EEF2F7</color>

    <!-- ============================================================
         UIX-8C-02 — Transaction / sync state semantics (UIX8C-R047).
         Each state has a distinct fg + bg drawn from the accessible
         status triads above; state is NEVER colour-alone (a text label
         and/or icon always accompanies these). Adding named tokens per
         state keeps sync/offline/pending semantics unambiguous and
         centralized rather than re-derived per screen.
         ============================================================ -->
    <!-- Online / synced (positive, settled) -->
    <color name="state_online_fg">#15803D</color>
    <color name="state_online_bg">#E7F4EA</color>
    <color name="state_synced_fg">#15803D</color>
    <color name="state_synced_bg">#E7F4EA</color>
    <!-- Pending / syncing (in-progress, informational) -->
    <color name="state_pending_fg">#1D4ED8</color>
    <color name="state_pending_bg">#E8EEFC</color>
    <color name="state_syncing_fg">#1D4ED8</color>
    <color name="state_syncing_bg">#E8EEFC</color>
    <!-- Offline / retrying / conflict (attention, not error) -->
    <color name="state_offline_fg">#B45309</color>
    <color name="state_offline_bg">#FBF0DC</color>
    <color name="state_retrying_fg">#B45309</color>
    <color name="state_retrying_bg">#FBF0DC</color>
    <color name="state_conflict_fg">#B45309</color>
    <color name="state_conflict_bg">#FBF0DC</color>
    <!-- Failed (error) -->
    <color name="state_failed_fg">#B91C1C</color>
    <color name="state_failed_bg">#FBE7E7</color>
    <!-- Disabled / unavailable (muted) -->
    <color name="state_disabled_fg">#9CA3AF</color>
    <color name="state_disabled_bg">#F1F4F9</color>

    <!-- Refined gold accent — sparing use only (never a large fill). -->
    <color name="accent_gold">#D6A84B</color>
</resources>
