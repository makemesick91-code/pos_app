<?xml version="1.0" encoding="utf-8"?>
<!-- Aish POS — Android dimension resources.
     Source of truth: operator-provided UI/UX handoff package (DESIGN_TOKENS.json / tokens/dimens.xml).
     UIX-1 Design Foundation Lock. 4dp spacing grid; touch target >= 48dp; pay button 52dp. -->
<resources>
    <!-- Spacing scale (4dp grid) -->
    <dimen name="space_xs">4dp</dimen>
    <dimen name="space_sm">8dp</dimen>
    <dimen name="space_md">12dp</dimen>
    <dimen name="space_lg">16dp</dimen>
    <dimen name="space_xl">24dp</dimen>
    <dimen name="space_2xl">32dp</dimen>
    <dimen name="space_3xl">48dp</dimen>

    <!-- Radius -->
    <dimen name="radius_input">8dp</dimen>
    <dimen name="radius_card">12dp</dimen>
    <dimen name="radius_sheet">16dp</dimen>
    <dimen name="radius_button">12dp</dimen>

    <!-- Touch targets -->
    <dimen name="touch_target_min">48dp</dimen>
    <dimen name="button_height">48dp</dimen>
    <dimen name="button_pay_height">52dp</dimen>
    <dimen name="input_height">48dp</dimen>
    <dimen name="stepper_size">48dp</dimen>

    <!-- Type sizes -->
    <dimen name="text_display">28sp</dimen>
    <dimen name="text_page_title">22sp</dimen>
    <dimen name="text_section_title">17sp</dimen>
    <dimen name="text_card_title">15sp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_body_small">13sp</dimen>
    <dimen name="text_label">12sp</dimen>
    <dimen name="text_caption">11.5sp</dimen>
    <dimen name="text_button">14sp</dimen>
    <dimen name="text_currency_large">30sp</dimen>
    <dimen name="text_numeric_table">13sp</dimen>

    <!-- Motion (ms, use as integer) -->
    <integer name="motion_fast">150</integer>
    <integer name="motion_standard">220</integer>
    <integer name="motion_emphasis">300</integer>
</resources>
