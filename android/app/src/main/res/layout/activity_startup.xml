<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="@dimen/cashier_product_min_height"
        android:padding="@dimen/space_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            android:text="@string/startup_title"
            android:textAppearance="@style/TextAppearance.Aish.Display" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg" />

        <TextView
            android:id="@+id/textProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:contentDescription="@string/cd_startup_progress"
            android:text="@string/startup_bootstrapping"
            android:textAppearance="@style/TextAppearance.Aish.Body" />

        <LinearLayout
            android:id="@+id/errorContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_lg"
            android:visibility="gone">

            <TextView
                android:id="@+id/textError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/action_destructive"
                android:textAppearance="@style/TextAppearance.Aish.Body" />

            <Button
                android:id="@+id/buttonRetry"
                style="@style/Widget.Aish.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:minHeight="@dimen/touch_target_min"
                android:text="@string/startup_retry" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
