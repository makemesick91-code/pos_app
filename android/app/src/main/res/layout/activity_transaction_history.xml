<?xml version="1.0" encoding="utf-8"?>
<!-- UIX-8B — transaction history. Per-transaction rows with explicit sync-state
     badges (text + colour, never colour alone), truthful loading/empty/error
     states. Read-only; tokenized and accessible. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_default"
    android:padding="@dimen/space_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history_title"
        android:textAppearance="@style/TextAppearance.Aish.PageTitle" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_md">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <ProgressBar
            android:id="@+id/progressHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textHistoryEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="@dimen/space_lg"
            android:text="@string/history_empty"
            android:textAppearance="@style/TextAppearance.Aish.Body"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
