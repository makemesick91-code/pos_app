<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/session_expired_title"
            android:textAppearance="@style/TextAppearance.Aish.PageTitle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/session_expired_body"
            android:textAppearance="@style/TextAppearance.Aish.Body" />

        <Button
            android:id="@+id/buttonRelogin"
            style="@style/Widget.Aish.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:minHeight="@dimen/touch_target_min"
            android:text="@string/session_expired_button" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
