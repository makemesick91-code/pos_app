<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/qris_title"
            android:textAppearance="@style/TextAppearance.Aish.PageTitle" />

        <TextView
            android:id="@+id/textSaleId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:textAppearance="@style/TextAppearance.Aish.Body" />

        <TextView
            android:id="@+id/textAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textAppearance="@style/TextAppearance.Aish.SectionTitle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/qris_payload_heading"
            android:textAppearance="@style/TextAppearance.Aish.Label" />

        <TextView
            android:id="@+id/textQrPayload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@color/scrim_subtle"
            android:padding="@dimen/space_md"
            android:fontFamily="monospace"
            android:textSize="@dimen/text_body_small"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="@string/cd_qris_receipt_affordance"
            android:textAppearance="@style/TextAppearance.Aish.Body" />

        <TextView
            android:id="@+id/textExpiredAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textAppearance="@style/TextAppearance.Aish.BodySmall" />

        <Button
            android:id="@+id/buttonRefresh"
            style="@style/Widget.Aish.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:minHeight="@dimen/touch_target_min"
            android:text="@string/qris_refresh" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_lg"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
