<?xml version="1.0" encoding="utf-8"?>
<!-- UIX-8C-06 — one receipt line: product name, qty x unit price, line total.
     Whole-rupiah values, font-scale safe (wraps, never clipped). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:paddingVertical="@dimen/space_xs">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textLineName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Aish.Body"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/textLineQtyPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Aish.Caption"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <TextView
        android:id="@+id/textLineTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:layout_gravity="top"
        android:textAppearance="@style/TextAppearance.Aish.MoneySecondary"
        android:textColor="@color/text_primary" />

</LinearLayout>
