<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/settings_title"
            android:textAppearance="@style/TextAppearance.Aish.PageTitle" />

        <!-- ============ 1. Akun & Konteks ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_account" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_tenant"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueTenant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_outlet"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueOutlet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_cashier"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueCashier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_role"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_lg"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <Button
                    android:id="@+id/buttonSwitchAccount"
                    style="@style/Widget.Aish.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_switch_account" />

                <Button
                    android:id="@+id/buttonLogoutAccount"
                    style="@style/Widget.Aish.Button.Destructive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_logout" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 2. Perangkat ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_device" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_device_name"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueDeviceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_activation"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueActivation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_activated_at"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueActivatedAt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_last_seen"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueLastSeen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_installation"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueInstallation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 3. Aplikasi ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_app" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_app_version"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueAppVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_version_code"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueVersionCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_build_type"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueBuildType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_package"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valuePackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_android"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueAndroid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_device_model"
                    android:textAppearance="@style/TextAppearance.Aish.Label" />

                <TextView
                    android:id="@+id/valueDeviceModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/state_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 4. Koneksi ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_connection" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/chipConnection"
                    style="@style/Widget.Aish.StatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/cd_connection_status"
                    android:text="@string/state_unavailable" />

                <Button
                    android:id="@+id/buttonCheckConnection"
                    style="@style/Widget.Aish.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_check_connection" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 5. Sinkronisasi ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_sync" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/chipSync"
                    style="@style/Widget.Aish.StatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/cd_settings_sync_status"
                    android:text="@string/state_unavailable" />

                <TextView
                    android:id="@+id/textPending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <Button
                    android:id="@+id/buttonSyncNow"
                    style="@style/Widget.Aish.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_sync_now" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 6. Printer ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_printer" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/textPrinterUnavailable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_printer_unavailable"
                    android:textAppearance="@style/TextAppearance.Aish.Body" />

                <Button
                    android:id="@+id/buttonPrinterSettings"
                    style="@style/Widget.Aish.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_printer_settings"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ============ 7. Keamanan & Sesi ============ -->
        <TextView
            style="@style/Widget.Aish.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_security" />

        <androidx.cardview.widget.CardView
            style="@style/Widget.Aish.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/chipSession"
                    style="@style/Widget.Aish.StatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/cd_session_status"
                    android:text="@string/state_unavailable" />

                <Button
                    android:id="@+id/buttonLogoutSecurity"
                    style="@style/Widget.Aish.Button.Destructive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_logout" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
