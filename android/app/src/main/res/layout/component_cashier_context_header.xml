<?xml version="1.0" encoding="utf-8"?>
<!-- UIX-8C-03 — canonical cashier context header (UIX8C-R061/R062, UIX8C-R049,
     UIX8B-R025): business / outlet / cashier / device identity + a truthful
     network state, fed only by authenticated auth/me (never client input,
     UIX8C-R063). Long names ellipsize (never clip a primary action, UIX8C-R049/
     R089). Status uses text + a chip colour, never colour alone (UIX8C-R047).
     Presentation only — no business logic. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contextHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:contentDescription="@string/cd_context_header"
    android:background="@color/surface_default"
    android:padding="@dimen/space_sm">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textContextBusiness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:contentDescription="@string/cd_context_business"
            android:text="@string/ctx_placeholder"
            android:textAppearance="@style/TextAppearance.Aish.Label" />

        <TextView
            android:id="@+id/textContextOutlet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/ctx_placeholder"
            android:textAppearance="@style/TextAppearance.Aish.CardTitle" />

        <TextView
            android:id="@+id/textContextCashier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/ctx_placeholder"
            android:textAppearance="@style/TextAppearance.Aish.Caption" />

        <TextView
            android:id="@+id/textContextDevice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:contentDescription="@string/cd_context_device"
            android:text="@string/ctx_placeholder"
            android:textAppearance="@style/TextAppearance.Aish.Caption" />
    </LinearLayout>

    <TextView
        android:id="@+id/chipNetwork"
        style="@style/Widget.Aish.StatusChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:backgroundTint="@color/state_online_bg"
        android:textColor="@color/state_online_fg"
        android:contentDescription="@string/cd_network_status"
        android:text="@string/ctx_network_online" />
</LinearLayout>
