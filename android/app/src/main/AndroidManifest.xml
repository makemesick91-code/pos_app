<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Backend catalog sync + auth over HTTP(S). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- UIX-8C-05 — observe default-network availability to give the cashier a
         truthful "connection restored, sync can resume" signal. Reachable code
         path: CashierActivity's default-network callback (least-privilege; the
         actual reconnect sync stays with the governed WorkManager scheduler). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Sprint 6 — Bluetooth ESC/POS receipt printing (paired device by MAC; no
         discovery, so no location permission). Legacy perms are capped at API 30;
         BLUETOOTH_CONNECT is the runtime permission on Android 12+. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- UIX-7 (UIX7-R006/R007/R026/R027) — auth tokens and the tenant-scoped Room
         DB must not leave the device via cloud/adb backup, and cleartext is denied
         by default (see res/xml/network_security_config.xml). -->
    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.AishPosLite">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".feature.cashier.CashierActivity"
            android:exported="false" />

        <activity
            android:name=".feature.qris.QrisPaymentActivity"
            android:exported="false" />

        <activity
            android:name=".feature.receipt.ReceiptActivity"
            android:exported="false" />

        <activity
            android:name=".feature.reports.ReportsActivity"
            android:exported="false" />

        <activity
            android:name=".feature.subscription.SubscriptionStatusActivity"
            android:exported="false" />

        <activity
            android:name=".feature.history.TransactionHistoryActivity"
            android:exported="false" />

        <!-- UIX-8C-07 — premium auth / device / settings / session recovery. -->
        <activity
            android:name=".feature.startup.StartupActivity"
            android:label="@string/app_name"
            android:exported="false" />

        <activity
            android:name=".feature.activation.DeviceActivationActivity"
            android:label="Aktivasi Perangkat"
            android:exported="false" />

        <activity
            android:name=".feature.session.SessionExpiredActivity"
            android:label="Sesi Berakhir"
            android:exported="false" />

        <activity
            android:name=".feature.session.DeviceRevokedActivity"
            android:label="Perangkat Dinonaktifkan"
            android:exported="false" />

        <activity
            android:name=".feature.settings.SettingsActivity"
            android:label="Pengaturan"
            android:exported="false" />

    </application>

</manifest>
