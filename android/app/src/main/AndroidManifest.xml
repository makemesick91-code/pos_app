<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Backend catalog sync + auth over HTTP(S). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Sprint 6 — Bluetooth ESC/POS receipt printing (paired device by MAC; no
         discovery, so no location permission). Legacy perms are capped at API 30;
         BLUETOOTH_CONNECT is the runtime permission on Android 12+. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.AishPosLite">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".feature.cashier.CashierActivity"
            android:exported="false" />

        <activity
            android:name=".feature.qris.QrisPaymentActivity"
            android:exported="false" />

        <activity
            android:name=".feature.receipt.ReceiptActivity"
            android:exported="false" />

    </application>

</manifest>
